    "instructions": {
      "title": "Information and Instructions for Completing Examination for Housebound Status or Permanent Need for Regular Aid and Attendance",
      "alert": "This form is used to document the medical findings that support a claim for Aid and Attendance or Housebound benefits. Please read all instructions carefully. The medical examination portion of this form must be completed by a licensed physician, physician assistant, or nurse practitioner.",
      "sections": [
        {
          "heading": "Purpose of This Form",
          "content": "Use this form, VA Form 21-2680, to provide medical evidence to support a claim for Special Monthly Compensation based on the need for regular Aid and Attendance of another person, or on account of being housebound. This examination provides VA with the medical information necessary to determine eligibility for these additional benefits."
        },
        {
          "heading": "Who Completes This Form",
          "content": "Sections I and II are completed by the veteran or claimant. Sections III through VIII must be completed by the examining physician, physician assistant (PA-C), or advanced practice registered nurse (APRN). The examiner must be a licensed medical professional."
        },
        {
          "heading": "Where to Submit This Form",
          "content": "Submit the completed form to:\n\nDepartment of Veterans Affairs\nEvidence Intake Center\nPO Box 4444\nJanesville, WI 53547-4444\n\nYou may also submit this form through your representative or at your local VA Regional Office."
        }
      ]
    },
